---
---

<div class="gate" id="gate" data-state="idle">
    <div class="content-wrapper">
        <div class="icon-container">
            <svg class="icon icon-lightning" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 2L3 14h9v8l10-12h-9l1-8z"/>
            </svg>
            
            <svg class="icon icon-clock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
            </svg>
            
            <svg class="icon icon-warning" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
        </div>

        <h1 id="title" class="title">Reaction Time Test</h1>
        <p id="instructions" class="instructions">Hit Space as quickly as you can once red turns green.</p>
        <p class="action-text" id="action-text">Space to start</p>
    </div>
</div>

<style>
    .gate {
        width: 100vw;
        height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        cursor: pointer; 
        user-select: none;
        padding: 2rem;
    }


    .gate[data-state="idle"] { background-color: var(--color-blue);}
    .gate[data-state="waiting"] { background-color: var(--color-red); cursor: cell; }
    .gate[data-state="go"] { background-color: var(--color-green); }
    .gate[data-state="too-soon"] { background: var(--color-blue); }
    .gate[data-state="result"] { background-color: var(--color-blue); }


    .content-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        max-width: 680px;
        width: 100%;
    }

    .icon-container { 
        margin-bottom: 2rem;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .icon {
        display: none;
        width: 80px;
        height: 80px;
        color: aliceblue;
    }

    .gate[data-state="idle"] .icon-lightning { display: block;}
    .gate[data-state="result"] .icon-clock { display: block; }
    .gate[data-state="too-soon"] .icon-warning { display: block; }

    .title {
        font-size: 5rem;
        font-weight: 800;
        marigin: 0 0 1rem 0;
        line-height: 1.1;
        letter-spacing: -0.03em;
    }

    .instructions {
        font-size: 1.5rem;
        margin: 0 0 2rem 0;
        font-weight: 400;
    }

    .action-text {
        font-size: 1.25rem;
        margin: 0;
        font-weight: 600;
        opacity: 0.8;
    }

    @media (max-width: 768px) {
        .title {
            font-size: 3.5rem;
        }
        .instructions {
            font-size: 1.25rem;
        }
    }


</style>

<script>

    const gate = document.getElementById("gate")!;
    const title = document.getElementById("title")!;
    const instructions = document.getElementById("instructions")!;
    const actionText = document.getElementById("action-text")!;

    let state = "idle";
    let timeoutId;
    let goTimestamp;

    function setState(next: string) {
        state = next;
        gate.dataset.state = next;
    }

    function startRound() {
        setState("waiting");
        title.textContent = "Wait for green...";
        instructions.textContent = '';
        actionText.textContent = '';
        const delay = 1000 + Math.random() * 3000;

        timeoutId = setTimeout(() => {
            goTimestamp = performance.now();
            setState("go");
            title.textContent = "Now!";
        }, delay)
    }

    document.addEventListener("keydown", (e) => {
        if (e.code !== "Space") return;
         

        e.preventDefault();
        if (state == "idle" || state === "result" || state === "too-soon") {
            startRound();
        } else if (state === "waiting") {
            clearTimeout(timeoutId!);
            setState('too-soon');
            title.textContent = 'A bit too soon spammer!';
            instructions.textContent = 'Hit space to try again';
        } else if (state === "go") {
            const reaction = Math.round(performance.now() - goTimestamp!);
            setState("result");
            title.textContent = `${reaction} ms`;
            instructions.textContent = "Hit space to try your skills again!";

        }
    });

</script>